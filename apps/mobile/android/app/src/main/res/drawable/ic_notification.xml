<!--
  FCM default notification icon — the small icon shown in the
  notification shade and on the lockscreen. Android 8+ requires it to
  be a single-color silhouette on transparent background; the system
  tints it (typically to white on the dark notification background)
  but the meta-data `default_notification_color` lets us override the
  tint to brand brass.

  Brand: the Cipher S — three offset bars forming an abstract "S" /
  three-redacted-bars motif. Same primary brand mark used on the
  launcher icon. Geometry matches the launcher master at
  apps/mobile/android/play/images/icon.png — bars 28 wide × 7 tall
  in a 100-unit viewport, L-R-L staircase. The in-app splash uses
  the cramped CipherS.tsx variant; launcher + notification share the
  spread variant so the system chrome reads as one icon.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="100"
    android:viewportHeight="100"
    android:tint="?attr/colorControlNormal">
  <path
      android:fillColor="@android:color/white"
      android:pathData="M30,37 L58,37 L58,44 L30,44 Z" />
  <path
      android:fillColor="@android:color/white"
      android:pathData="M42,46 L70,46 L70,53 L42,53 Z" />
  <path
      android:fillColor="@android:color/white"
      android:pathData="M30,55 L58,55 L58,62 L30,62 Z" />
</vector>
