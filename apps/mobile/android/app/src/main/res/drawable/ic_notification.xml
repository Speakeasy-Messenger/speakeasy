<!--
  FCM default notification icon — the small icon shown in the
  notification shade and on the lockscreen. Android 8+ requires it to
  be a single-color silhouette on transparent background; the system
  tints it (typically to white on the dark notification background)
  but the meta-data `default_notification_color` lets us override the
  tint to brand brass.

  Brand: the Cipher S — three offset bars forming an abstract "S" /
  three-redacted-bars motif. Same primary brand mark as the launcher,
  but deliberately BOLDER: the launcher mark is padded (x:28-72) so its
  bars survive the round/squircle adaptive-icon mask, whereas this
  silhouette has no mask and the system renders it tiny in the status
  bar (and inside a small tinted badge in the shade). Reusing the
  launcher's padding made the mark look shrunken, so the notification
  fills its canvas instead: bars 50 wide × 10 tall, L-R-L staircase
  (x:13-87, y:20-80), leaving only a hair of margin for the system's
  own inset. The in-app splash uses the cramped CipherS.tsx variant.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="100"
    android:viewportHeight="100"
    android:tint="?attr/colorControlNormal">
  <path
      android:fillColor="@android:color/white"
      android:pathData="M13,20 L63,20 L63,30 L13,30 Z" />
  <path
      android:fillColor="@android:color/white"
      android:pathData="M37,45 L87,45 L87,55 L37,55 Z" />
  <path
      android:fillColor="@android:color/white"
      android:pathData="M13,70 L63,70 L63,80 L13,80 Z" />
</vector>
