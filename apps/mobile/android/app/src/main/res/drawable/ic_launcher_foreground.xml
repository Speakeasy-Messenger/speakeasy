<?xml version="1.0" encoding="utf-8"?>
<!--
  Cipher S — adaptive icon foreground.

  Three flat brass bars in the LEFT-RIGHT-LEFT cipher pattern. The
  earlier metallic-gradient + ambient-shadow + edge-highlight pass was
  retired with the rebrand to a flat mark; the new look is the canonical
  one for launcher, notification, and Play Store surfaces.

  Geometry matches the Play Store listing mark exactly (the bold,
  spread staircase the store shows): bars are 36 units wide × 8 tall
  in a 100-unit viewport, L-R-L, spanning x:23-77, y:29-71 with
  ~9-unit vertical gaps. That's the listing's bold geometry scaled
  in ~18% toward center so the bar ends clear every launcher mask
  (round, squircle, square) — keeping the launcher and the store icon
  pixel-identical while staying inside the adaptive-icon safe zone.

  Vector drawable: scales to any density at install time, so we don't
  have to maintain mipmap-mdpi/…/xxxhdpi PNGs for the foreground.
  Pre-v26 devices use the bundled PNGs at mipmap/ic_launcher.png.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="100"
    android:viewportHeight="100">

  <path
      android:pathData="M23,29 L59,29 L59,37 L23,37 Z"
      android:fillColor="#E5A645"/>

  <path
      android:pathData="M41,46 L77,46 L77,54 L41,54 Z"
      android:fillColor="#E5A645"/>

  <path
      android:pathData="M23,63 L59,63 L59,71 L23,71 Z"
      android:fillColor="#E5A645"/>
</vector>
