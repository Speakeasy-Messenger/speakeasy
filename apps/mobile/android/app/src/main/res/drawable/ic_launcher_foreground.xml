<?xml version="1.0" encoding="utf-8"?>
<!--
  Cipher S — metallic adaptive icon foreground.

  Three brass bars rendered with a diagonal gradient (highlight on the
  top-left, shadow toward the bottom-right) plus a thin top-edge
  highlight and a soft ambient shadow underneath. The effect is a
  premium metallic sheen in the vein of Linear's launcher icon —
  brass that looks struck, not flat.

  Geometry mirrors src/brand/CipherS.tsx's LEFT-RIGHT-LEFT cipher
  pattern, but scaled to ~70% of the viewport so the mark sits inside
  the adaptive-icon safe zone (72/108 dp ≈ 16-84 in this 100×100
  viewport). The previous spread (x:5-95) read right up to the icon's
  edges and got clipped by Samsung's squircle mask; this version
  leaves a comfortable ring of margin all around.

  Vector drawable: scales to any density at install time, so we don't
  have to maintain mipmap-mdpi/…/xxxhdpi PNGs for the foreground.
  Pre-v26 devices keep using the bundled PNGs at mipmap/ic_launcher.png.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="100"
    android:viewportHeight="100">

  <!-- Bar 1: ambient shadow underneath, offset down + right 0.5 -->
  <path
      android:pathData="M16.5,26.7 L60.5,26.7 L60.5,37.7 L16.5,37.7 Z"
      android:fillColor="#3A2A0E"
      android:fillAlpha="0.45"/>

  <!-- Bar 1: main, diagonal metallic gradient -->
  <path android:pathData="M16,26 L60,26 L60,37 L16,37 Z">
    <aapt:attr name="android:fillColor">
      <gradient
          android:type="linear"
          android:startX="16" android:startY="26"
          android:endX="60" android:endY="37">
        <item android:offset="0.0" android:color="#FCE4A4"/>
        <item android:offset="0.20" android:color="#F2C167"/>
        <item android:offset="0.50" android:color="#E5A645"/>
        <item android:offset="0.80" android:color="#B07E2C"/>
        <item android:offset="1.0" android:color="#7E5A1C"/>
      </gradient>
    </aapt:attr>
  </path>

  <!-- Bar 1: top-edge highlight -->
  <path
      android:pathData="M16,26 L60,26 L60,27.2 L16,27.2 Z"
      android:fillColor="#FFF4D0"
      android:fillAlpha="0.55"/>

  <!-- Bar 2: ambient shadow underneath -->
  <path
      android:pathData="M40.5,44.7 L84.5,44.7 L84.5,55.7 L40.5,55.7 Z"
      android:fillColor="#3A2A0E"
      android:fillAlpha="0.45"/>

  <!-- Bar 2: main, diagonal metallic gradient -->
  <path android:pathData="M40,44 L84,44 L84,55 L40,55 Z">
    <aapt:attr name="android:fillColor">
      <gradient
          android:type="linear"
          android:startX="40" android:startY="44"
          android:endX="84" android:endY="55">
        <item android:offset="0.0" android:color="#FCE4A4"/>
        <item android:offset="0.20" android:color="#F2C167"/>
        <item android:offset="0.50" android:color="#E5A645"/>
        <item android:offset="0.80" android:color="#B07E2C"/>
        <item android:offset="1.0" android:color="#7E5A1C"/>
      </gradient>
    </aapt:attr>
  </path>

  <!-- Bar 2: top-edge highlight -->
  <path
      android:pathData="M40,44 L84,44 L84,45.2 L40,45.2 Z"
      android:fillColor="#FFF4D0"
      android:fillAlpha="0.55"/>

  <!-- Bar 3: ambient shadow underneath -->
  <path
      android:pathData="M16.5,62.7 L60.5,62.7 L60.5,73.7 L16.5,73.7 Z"
      android:fillColor="#3A2A0E"
      android:fillAlpha="0.45"/>

  <!-- Bar 3: main, diagonal metallic gradient -->
  <path android:pathData="M16,62 L60,62 L60,73 L16,73 Z">
    <aapt:attr name="android:fillColor">
      <gradient
          android:type="linear"
          android:startX="16" android:startY="62"
          android:endX="60" android:endY="73">
        <item android:offset="0.0" android:color="#FCE4A4"/>
        <item android:offset="0.20" android:color="#F2C167"/>
        <item android:offset="0.50" android:color="#E5A645"/>
        <item android:offset="0.80" android:color="#B07E2C"/>
        <item android:offset="1.0" android:color="#7E5A1C"/>
      </gradient>
    </aapt:attr>
  </path>

  <!-- Bar 3: top-edge highlight -->
  <path
      android:pathData="M16,62 L60,62 L60,63.2 L16,63.2 Z"
      android:fillColor="#FFF4D0"
      android:fillAlpha="0.55"/>
</vector>
