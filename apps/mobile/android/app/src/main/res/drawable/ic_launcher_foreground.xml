<?xml version="1.0" encoding="utf-8"?>
<!--
  Cipher S — adaptive icon foreground.

  Three flat brass bars in the LEFT-RIGHT-LEFT cipher pattern. The
  earlier metallic-gradient + ambient-shadow + edge-highlight pass was
  retired with the rebrand to a flat mark; the new look is the canonical
  one for launcher, notification, and Play Store surfaces.

  Geometry matches the 512px master (apps/mobile/android/play/images/
  icon.png): bars are 28 units wide × 7 tall in a 100-unit viewport,
  with the staircase pattern (L-R-L) and ~2-unit vertical gaps. The
  mark spans x:30-70, y:37-62 — the same comfortably-padded footprint
  the pre-flat icon used, so all three bars sit well inside the
  adaptive-icon safe zone (inner 66% of the 108dp canvas) and survive
  every launcher mask (round, squircle, square) without truncation.

  Vector drawable: scales to any density at install time, so we don't
  have to maintain mipmap-mdpi/…/xxxhdpi PNGs for the foreground.
  Pre-v26 devices use the bundled PNGs at mipmap/ic_launcher.png.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="100"
    android:viewportHeight="100">

  <path
      android:pathData="M30,37 L58,37 L58,44 L30,44 Z"
      android:fillColor="#E5A645"/>

  <path
      android:pathData="M42,46 L70,46 L70,53 L42,53 Z"
      android:fillColor="#E5A645"/>

  <path
      android:pathData="M30,55 L58,55 L58,62 L30,62 Z"
      android:fillColor="#E5A645"/>
</vector>
