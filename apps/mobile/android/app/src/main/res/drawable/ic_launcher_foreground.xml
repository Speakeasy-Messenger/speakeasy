<?xml version="1.0" encoding="utf-8"?>
<!--
  Cipher S — adaptive icon foreground.

  Three flat brass bars in the LEFT-RIGHT-LEFT cipher pattern. The
  earlier metallic-gradient + ambient-shadow + edge-highlight pass was
  retired with the rebrand to a flat mark; the new look is the canonical
  one for launcher, notification, and Play Store surfaces.

  Geometry matches the Play Store listing mark exactly (the bold,
  spread staircase the store shows): bars are 29 units wide × 8 tall
  in a 100-unit viewport, L-R-L, spanning x:28-72, y:32-68 with
  ~6-unit vertical gaps. The mark's farthest corner sits ~31dp from
  centre on the 108dp canvas — comfortably inside the 36dp safe zone,
  so all three bars have visible breathing room on every launcher mask
  (round, squircle, square). Launcher and store icon stay pixel-identical.

  Vector drawable: scales to any density at install time, so we don't
  have to maintain mipmap-mdpi/…/xxxhdpi PNGs for the foreground.
  Pre-v26 devices use the bundled PNGs at mipmap/ic_launcher.png.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="100"
    android:viewportHeight="100">

  <path
      android:pathData="M28,32 L57,32 L57,40 L28,40 Z"
      android:fillColor="#E5A645"/>

  <path
      android:pathData="M43,46 L72,46 L72,54 L43,54 Z"
      android:fillColor="#E5A645"/>

  <path
      android:pathData="M28,60 L57,60 L57,68 L28,68 Z"
      android:fillColor="#E5A645"/>
</vector>
