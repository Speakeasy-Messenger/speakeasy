<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Android 15 (API 35) override of AppTheme.

        On targetSdk 35 the framework FORCES edge-to-edge layout: the
        system bars become transparent overlays and app content draws
        under them. Apps must either handle WindowInsets themselves
        (via react-native-safe-area-context) or opt out and keep the
        legacy "system bars push content" behavior.

        v1.0.1-hotfix.2: the opt-out is RESTORED. The hotfix.1 re-cut
        removed it to adopt real edge-to-edge, but on RN 0.77 + targetSdk
        35 that regressed live behavior on-device: with the window
        edge-to-edge, `windowSoftInputMode=adjustResize` no longer pushes
        the chat composer above the keyboard (composer hidden behind the
        IME), and the conversations FAB / bottom content rendered under
        the nav bar. Edge-to-edge is a Play *recommendation* (non-blocking
        — 1.0.0 shipped with this opt-out), so we keep it OFF here and
        ship the mandatory 16 KB fix. Real edge-to-edge (IME inset
        handling + per-screen insets, device-verified) is deferred to its
        own follow-up.

        This file lives under `values-v35/` so the override is only
        applied on API 35+; older platforms keep the base theme.
    -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:editTextBackground">@drawable/rn_edit_text_material</item>
        <item name="android:windowOptOutEdgeToEdgeEnforcement">true</item>
    </style>

</resources>
