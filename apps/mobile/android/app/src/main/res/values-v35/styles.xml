<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Android 15 (API 35) override of AppTheme.

        On targetSdk 35 the framework FORCES edge-to-edge layout: the
        system bars become transparent overlays and app content draws
        under them. Apps must either handle WindowInsets themselves
        (via react-native-safe-area-context) or opt out and keep the
        legacy "system bars push content" behavior.

        v1.0.1 16 KB / edge-to-edge re-cut: the opt-out
        (`android:windowOptOutEdgeToEdgeEnforcement`) is REMOVED. The
        earlier opt-out existed because react-native-safe-area-context
        4.x did not reliably forward the API-35 bar insets through the RN
        view tree (testers saw the chat input behind the nav bar and the
        AppBar under the status bar even after the SafeAreaView swap in
        PR #104). The bump to safe-area-context 5.x fixes that inset
        forwarding, so the app now handles edge-to-edge itself via
        SafeAreaView / useSafeAreaInsets app-wide (incl. bottom-sheet
        nav-bar insets) — clearing Play Console recommendations #1
        (edge-to-edge) and #2 (deprecated window APIs). The opt-out was
        also API-35-only; API 36 removes the escape hatch entirely.

        This file lives under `values-v35/` so the override is only
        applied on API 35+; older platforms keep the base theme.
    -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:editTextBackground">@drawable/rn_edit_text_material</item>
    </style>

</resources>
