<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- READ_CONTACTS was declared in earlier rcs as a placeholder for a
         since-cancelled InviteFriendsScreen. No code path ever read the
         contact list (the npm dep `react-native-contacts` had zero JS
         imports), and ShareHandleScreen uses Share/QR/Clipboard
         instead. Permission + dep both dropped in rc.33 so Play
         Console's permission scanner doesn't flag a permission we
         don't use. -->

    <!-- Push notifications. Android 13+ (API 33) requires this permission
         at runtime; without it, the OS silently drops every FCM-delivered
         banner. rc.27→rc.32 had every other piece of push wiring working
         (token registered, FCM accepted, server delivered) but no banner
         appeared on device until this was added. Requested via
         PermissionsAndroid in push-notifications.ts. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />


    <!-- Phase 6 voice calling: WebRTC + ConnectionService prerequisites. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <!-- Phase 6 video calling: camera + the API 34+ foreground-service
         type. CAMERA is requested at runtime via PermissionsAndroid
         immediately before getUserMedia({ video: true }) — see
         VideoCallScreen / orchestrator.startOutgoing(kind='video'). -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.front" android:required="false" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <!-- ConnectionService (native ring UI). Required for CallKeep on
         Android 9+. The user grants the phone-account permission once
         via the system "Calling apps" prompt CallKeep raises on first
         setup; without it CallKeep silently degrades to in-app UI. -->
    <uses-permission android:name="android.permission.MANAGE_OWN_CALLS" />
    <uses-permission android:name="android.permission.READ_PHONE_NUMBERS" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <!-- Foreground service while a call is active. CallKeep's Android
         module starts the service so the OS doesn't kill the JS engine
         mid-call. `microphone` type is required on API 34+. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_PHONE_CALL" />
    <!-- Full-screen incoming-call ringing (#5). Presents a full-screen call
         UI over the lock screen instead of just a banner. On Android 14+
         this permission additionally requires a one-time full-screen-intent
         DECLARATION in the Play Console (Policy → App content) before Play
         will accept an upload — the app's use (incoming calls) qualifies.
         Without that declaration the Play commit fails with HTTP 403
         "You must let us know whether your app uses any full-screen intent
         permissions". -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <application
      android:name=".MainApplication"
      android:label="@string/app_name"
      android:icon="@mipmap/ic_launcher"
      android:roundIcon="@mipmap/ic_launcher_round"
      android:allowBackup="true"
      android:fullBackupContent="@xml/backup_rules"
      android:dataExtractionRules="@xml/data_extraction_rules"
      android:theme="@style/AppTheme"
      android:networkSecurityConfig="@xml/network_security_config"
      android:supportsRtl="true">
      <activity
        android:name=".MainActivity"
        android:label="@string/app_name"
        android:configChanges="keyboard|keyboardHidden|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
        android:launchMode="singleTask"
        android:screenOrientation="portrait"
        android:supportsPictureInPicture="true"
        android:windowSoftInputMode="adjustResize"
        android:exported="true">
        <!-- showWhenLocked / turnScreenOn are deliberately NOT declared as
             static attributes. As static manifest attributes they applied to
             the whole app for its entire lifetime, so any screen-on event
             with Speakeasy foregrounded (e.g. lock the device on the chat
             list, then press power) rendered the chat list OVER the lock
             screen — a privacy leak. They are now toggled programmatically
             only while a call is ringing/active via the SpeakeasyLockScreen
             native module (lockscreen/LockScreenModule.kt) driven from
             src/native/lock-screen.ts. -->

        <intent-filter>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent-filter>
        <!-- Deep link: speakeasy://add?handle=<handle>. Encoded in
             user QR codes so the OS camera (or any other QR scanner)
             can hand off to Speakeasy directly. The MainActivity
             receives the URI via getIntent()/Linking.getInitialURL
             and routes to NewChat with the handle prefilled. -->
        <intent-filter android:autoVerify="false">
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.DEFAULT" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="speakeasy" android:host="add" />
        </intent-filter>
        <!-- App Link: https://speakeasyapp.xyz/add?handle=<handle>. The
             canonical shareable link (also the QR value). autoVerify lets
             Android verify ownership via the domain's
             /.well-known/assetlinks.json and open the app directly instead
             of the browser. Same MainActivity handler (Linking → parseAdd).
             A shared link that the app can't open (not installed) falls
             back to the speakeasyapp.xyz/add web page → Play download. -->
        <intent-filter android:autoVerify="true">
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.DEFAULT" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="https" android:host="speakeasyapp.xyz" android:pathPrefix="/add" />
        </intent-filter>
        <!-- Share target: other apps' "Share → Speakeasy" for text/links.
             MainActivity.onCreate/onNewIntent stash the EXTRA_TEXT via
             ShareModule; JS drains it and opens a "Send to…" picker. -->
        <intent-filter>
            <action android:name="android.intent.action.SEND" />
            <category android:name="android.intent.category.DEFAULT" />
            <data android:mimeType="text/plain" />
        </intent-filter>
      </activity>

      <provider
        android:name="androidx.core.content.FileProvider"
        android:authorities="${applicationId}.fileprovider"
        android:exported="false"
        android:grantUriPermissions="true">
        <meta-data
          android:name="android.support.FILE_PROVIDER_PATHS"
          android:resource="@xml/file_paths" />
      </provider>

      <!-- FCM default notification icon + channel. Without these,
           Android 8+ falls back to the launcher icon (which is colored,
           and the system will reject it as a notification icon — silently
           drops the banner) and a generic channel that may not be
           visible in the notification shade. The icon is a white-on-
           transparent vector drawable in res/drawable. The channel id
           is created on first delivery if it doesn't exist. -->
      <meta-data
        android:name="com.google.firebase.messaging.default_notification_icon"
        android:resource="@drawable/ic_notification"
        tools:replace="android:resource" />
      <meta-data
        android:name="com.google.firebase.messaging.default_notification_color"
        android:resource="@color/notification_brass"
        tools:replace="android:resource" />
      <meta-data
        android:name="com.google.firebase.messaging.default_notification_channel_id"
        android:value="speakeasy_default"
        tools:replace="android:value" />

      <!-- CallKeep VoiceConnectionService — required for CallKit/Connection-
           Service ring UI on Android. The lib's own AndroidManifest.xml
           declares the permissions but NOT this service, so each app has
           to register it explicitly.
           See https://github.com/react-native-webrtc/react-native-callkeep#android -->
      <service
        android:name="io.wazo.callkeep.VoiceConnectionService"
        android:label="Speakeasy"
        android:permission="android.permission.BIND_TELECOM_CONNECTION_SERVICE"
        android:foregroundServiceType="microphone"
        android:exported="true">
        <intent-filter>
            <action android:name="android.telecom.ConnectionService" />
        </intent-filter>
      </service>
      <!-- notifee's foreground service, backing the ongoing voice-call pill.
           WITHOUT an FGS, Samsung/One UI freezes & kills a backgrounded audio
           call within seconds — taking the pill AND the call's WS down with it
           (the reported "pill never shows on Android"). `microphone` is the
           correct type: the live call holds RECORD_AUDIO, and the service is
           started while the app is foreground at call-connect (so Android 14's
           background-FGS-start restriction doesn't apply). tools:replace forces
           our type onto notifee-core's service declaration. -->
      <service
        android:name="app.notifee.core.ForegroundService"
        android:foregroundServiceType="microphone"
        tools:replace="android:foregroundServiceType" />
      <!-- Disable FCM notification delegation (v24+ feature that breaks JS handlers) -->
      <meta-data
        android:name="com.google.firebase.messaging.notification_delegation_enabled"
        android:value="false" />

      <!-- Native messaging notification — bypasses notifee for image
           loading because notifee's bundled Fresco pipeline silently
           drops every URI scheme we tried for runtime-cached avatar
           PNGs. NotifMessagingModule posts the MessagingStyle
           notification with bitmaps loaded directly via
           BitmapFactory.decodeFile; inline reply flows through this
           receiver + headless service back to the JS reply handler. -->
      <receiver
        android:name=".notif.NotifMessagingReplyReceiver"
        android:exported="false">
        <intent-filter>
          <action android:name="xyz.speakeasyapp.app.NOTIF_REPLY" />
        </intent-filter>
      </receiver>
      <service
        android:name=".notif.NotifMessagingReplyService"
        android:exported="false" />
    </application>
</manifest>
