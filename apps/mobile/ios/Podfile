# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'Speakeasy' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  # Phase 5b iOS: native dependencies for the four custom bridges. These
  # mirror the Android coordinates in `android/app/build.gradle`:
  #   dev.vouchflow:android-sdk:2.0.0       → Vouchflow iOS SDK
  #   org.signal:libsignal-android:0.59.0   → LibSignalClient
  #   net.zetetic:sqlcipher-android:4.14.1  → SQLCipher
  #
  # Vouchflow iOS — SPM-only distribution (no podspec on CocoaPods Trunk).
  # Added via Xcode: File → Add Package Dependencies → paste URL:
  #   https://github.com/vouchflow/ios-sdk
  # **Pin: exact 2.0.0** (matches the Android coordinate
  # `dev.vouchflow:android-sdk:2.0.0` — required for fallback OTP,
  # new VouchflowResult fields, and sessionId on biometric errors).

  # libsignal-client iOS — git-based CocoaPods dep (the canonical install
  # path per signalapp/libsignal's swift/README.md). The pod's
  # prepare_command builds the Rust library, OR downloads a prebuilt
  # binary if `LIBSIGNAL_FFI_PREBUILD_CHECKSUM` is set in the env.
  #
  # We use the prebuild path so the first `pod install` doesn't trigger
  # a 10+ min Rust compile. The checksum below is for libsignal v0.59.0,
  # pulled from the GitHub release artifact:
  #   github.com/signalapp/libsignal/releases/download/v0.59.0/libsignal-client-ios-build-v0.59.0.tar.gz.sha256
  ENV['LIBSIGNAL_FFI_PREBUILD_CHECKSUM'] =
    '32eac8d2c22768caf4015d6b039b93f8a0c03db3896c7802f8a02b85fd2765e8'
  pod 'LibSignalClient', git: 'https://github.com/signalapp/libsignal.git', tag: 'v0.59.0'

  # SQLCipher iOS — same DB encryption library as the Android side.
  pod 'SQLCipher', '~> 4.6.0'

  target 'SpeakeasyTests' do
    inherit! :complete
    # Pods for testing
  end

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # RN 0.77 bundles {fmt} 11.0.2 (pinned exactly by RCT-Folly). On modern
    # Apple Clang (Xcode 16.3+ / 26) fmt 11.0.2's internal FMT_COMPILE_STRING
    # call sites trip "call to consteval function ... is not a constant
    # expression" in fmt/format-inl.h, failing the fmt pod compile (fixed
    # upstream in fmt 11.1, but RCT-Folly can't take it; RN 0.76.5's older
    # fmt didn't hit this). A -DFMT_USE_CONSTEVAL=0 define doesn't help —
    # fmt/base.h *redefines* FMT_USE_CONSTEVAL itself by compiler detection
    # (Apple clang >=14 -> 1), overriding any predefine. So patch base.h
    # directly to force the consteval branches off: FMT_CONSTEVAL then
    # expands to empty (constexpr-only format-string checking) instead of
    # `consteval` — no runtime behavior change. Idempotent; re-applied on
    # every pod install.
    fmt_base = File.join(installer.sandbox.root, 'fmt', 'include', 'fmt', 'base.h')
    if File.exist?(fmt_base)
      contents = File.read(fmt_base)
      patched = contents.gsub("#  define FMT_USE_CONSTEVAL 1", "#  define FMT_USE_CONSTEVAL 0")
      if patched != contents
        # CocoaPods marks pod source files read-only — make writable first.
        File.chmod(0644, fmt_base)
        File.write(fmt_base, patched)
        Pod::UI.puts "[Speakeasy] Patched fmt base.h: FMT_USE_CONSTEVAL forced 0 (Xcode 16.3+ consteval fix)".green
      end
    end

    # SQLCipher must be the ONLY sqlite3 the app links. Some pod pulls in the
    # SYSTEM libsqlite3 via `-l"sqlite3"` in the aggregate target's
    # OTHER_LDFLAGS. The system sqlite3 has no encryption, so its sqlite3_key
    # shadows SQLCipher's and returns SQLITE_MISUSE (rc=21) at runtime — the
    # encrypted Signal store can't open ("identity_key_failed"), so the iOS
    # app can't send/receive. Strip the system sqlite3 link from every
    # aggregate target so SQLCipher's symbols win. (Caught 2026-06-21 running
    # the app on the iOS simulator; affects device builds too. The documented
    # SQLCipher-with-CocoaPods fix.)
    installer.aggregate_targets.each do |aggregate_target|
      aggregate_target.xcconfigs.each do |config_name, config_file|
        config_file.libraries.delete('sqlite3')
        config_file.save_as(aggregate_target.xcconfig_path(config_name))
      end
    end
  end
end

# Rich-push Notification Service Extension. It decrypts the forwarded ciphertext
# in its own process, so it needs the SAME libsignal the app uses. (SQLCipher is
# added when PushDecryptKit needs the shared DB.) The `NotificationService`
# Xcode target is created by tools/wire-ios-project.rb, which the build runs
# BEFORE pod install so CocoaPods can integrate this pod into it.
target 'NotificationService' do
  pod 'LibSignalClient', git: 'https://github.com/signalapp/libsignal.git', tag: 'v0.59.0'
  # The extension opens the shared encrypted store to decrypt + dedup, so it
  # needs the same SQLCipher the app uses.
  pod 'SQLCipher', '~> 4.6.0'
end
