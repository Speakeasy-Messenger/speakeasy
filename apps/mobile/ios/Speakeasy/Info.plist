<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
	<string>Speakeasy</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSAppTransportSecurity</key>
	<dict>
	  <!-- Do not change NSAllowsArbitraryLoads to true, or you will risk app rejection! -->
		<key>NSAllowsArbitraryLoads</key>
		<false/>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<!-- Phase 5b iOS: required for Vouchflow's biometric verify step (Face ID
	     prompts use this string). Wording mirrors the Android Vouchflow
	     onboarding tone. -->
	<key>NSFaceIDUsageDescription</key>
	<string>Speakeasy uses Face ID to verify this is your device. No personal info or biometrics are sent off-device.</string>
	<!-- Phase 6 voice calling: WebRTC needs the microphone. Wording stays
	     terse and on-brand — this is the iOS permission prompt copy. -->
	<key>NSMicrophoneUsageDescription</key>
	<string>Speakeasy needs the microphone to make voice calls.</string>
	<!-- Phase 6 video calling: WebRTC needs the camera. iOS gates
	     getUserMedia({ video: true }) on this string being present;
	     omitting it crashes the app the moment a video call starts. -->
	<key>NSCameraUsageDescription</key>
	<string>Speakeasy needs the camera for video calls. The video stream is end-to-end encrypted with the peer; nothing is recorded or stored on a server.</string>
	<!-- Attachments: react-native-image-picker's launchImageLibrary reads from
	     the photo library so you can pick photos/videos to send. iOS requires
	     this purpose string whenever the binary references the Photos API —
	     omitting it fails App Store ingestion with ITMS-90683. -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Speakeasy needs access to your photo library so you can choose photos and videos to send in an end-to-end encrypted chat. Anything you don't select stays on your device and is never uploaded.</string>
	<!-- Export compliance. Speakeasy uses encryption only for standard,
	     mass-market purposes (E2E messaging/calls via libsignal + HTTPS),
	     which qualifies for the exemptions in Category 5 Part 2 of the U.S.
	     EAR — the same basis Signal/WhatsApp rely on. Declaring it here
	     (false = "no non-exempt encryption / exemption applies") stops App
	     Store Connect prompting "Missing Compliance" on every TestFlight
	     build. If legal prefers to file an annual self-classification report
	     instead, flip this to <true/> and complete the export questionnaire. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<!-- VoIP + audio background modes — VoIP keeps the app's network
	     stack alive so an in-flight call survives a screen lock; audio
	     keeps the call audio session running while the screen is off.
	     remote-notification lets a data/content-available push wake the
	     app in the background to decrypt + post the message notification
	     (parity with Android's FCM background message handling). -->
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
		<string>voip</string>
		<string>remote-notification</string>
	</array>
	<!-- Deep link: speakeasy://add?handle=<handle>. Encoded in user QR
	     codes so the iOS camera can hand off to Speakeasy directly. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>xyz.speakeasyapp.app</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>speakeasy</string>
			</array>
		</dict>
	</array>
	<!-- Brand fonts. Place the .ttf files in Speakeasy/Fonts/ and add them to
	     the Xcode target's "Copy Bundle Resources" build phase before they
	     resolve at runtime. Filenames must match `src/theme/typography.ts`. -->
	<key>UIAppFonts</key>
	<array>
		<string>Inter-Light.ttf</string>
		<string>Inter-Regular.ttf</string>
		<string>Inter-Medium.ttf</string>
	</array>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<false/>
</dict>
</plist>
