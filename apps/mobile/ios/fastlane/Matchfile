git_url("git@github.com:Speakeasy-Messenger/speakeasy-certs.git")
storage_mode("git")

# App Store distribution certificate + provisioning profile. The
# 'development' type can be added later if we want device debug builds
# signed via match too.
type("appstore")

app_identifier(["xyz.speakeasyapp.app"])

# Auth is via the App Store Connect API key (see Fastfile `asc_api_key`),
# so no Apple ID username is needed here. On CI, match runs read-only and
# only consumes what was generated by the first local `fastlane ios certs`.
