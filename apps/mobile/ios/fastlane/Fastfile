# Speakeasy iOS — fastlane lanes.
#
# Auth: App Store Connect API key (no Apple ID password / 2FA). The key
# parts are injected via env (sourced from the squire vault locally, and
# from GitHub Actions secrets in CI):
#   ASC_KEY_ID            — the key id (e.g. YJV2ZFM84L)
#   ASC_ISSUER_ID         — the issuer UUID
#   ASC_KEY_CONTENT       — the .p8 private key contents (PEM, with newlines)
#   ASC_KEY_CONTENT_BASE64 — "true" if ASC_KEY_CONTENT is base64-encoded
# Signing: fastlane match (git storage — Speakeasy-Messenger/speakeasy-certs),
#   unlocked with MATCH_PASSWORD.
#
# Pods must be installed first (USE_FRAMEWORKS=static — LibSignalClient is a
# Swift pod). The CI workflow + the `pods` lane handle that.

default_platform(:ios)

APP_IDENTIFIER = "xyz.speakeasyapp.app".freeze
WORKSPACE = "Speakeasy.xcworkspace".freeze
SCHEME = "Speakeasy".freeze
TEAM_ID = "89KT3SWYAF".freeze
PROFILE = "match AppStore #{APP_IDENTIFIER}".freeze
# Share Extension target — its own bundle id + match profile (App Group).
EXT_IDENTIFIER = "xyz.speakeasyapp.app.ShareExtension".freeze
EXT_PROFILE = "match AppStore #{EXT_IDENTIFIER}".freeze
# Notification Service Extension — own bundle id + match profile (App Group,
# for the shared SQLCipher store the rich-push decrypt reads).
NSE_IDENTIFIER = "xyz.speakeasyapp.app.NotificationService".freeze
NSE_PROFILE = "match AppStore #{NSE_IDENTIFIER}".freeze

def asc_api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_content: ENV.fetch("ASC_KEY_CONTENT"),
    is_key_content_base64: ENV["ASC_KEY_CONTENT_BASE64"] == "true",
    in_house: false,
  )
end

# Pin manual signing + the match profile on the app target at build time,
# so we never depend on whatever signing the checked-in pbxproj happens to
# carry. Ephemeral on CI; on a dev Mac it edits the project — `git checkout`
# the pbxproj afterward if you don't want the change.
def pin_signing
  update_code_signing_settings(
    path: "Speakeasy.xcodeproj",
    use_automatic_signing: false,
    team_id: TEAM_ID,
    bundle_identifier: APP_IDENTIFIER,
    code_sign_identity: "Apple Distribution",
    profile_name: PROFILE,
    targets: ["Speakeasy"],
  )
  # Same, for the Share Extension target (its own bundle id + profile).
  update_code_signing_settings(
    path: "Speakeasy.xcodeproj",
    use_automatic_signing: false,
    team_id: TEAM_ID,
    bundle_identifier: EXT_IDENTIFIER,
    code_sign_identity: "Apple Distribution",
    profile_name: EXT_PROFILE,
    targets: ["ShareExtension"],
  )
  # Same, for the Notification Service Extension.
  update_code_signing_settings(
    path: "Speakeasy.xcodeproj",
    use_automatic_signing: false,
    team_id: TEAM_ID,
    bundle_identifier: NSE_IDENTIFIER,
    code_sign_identity: "Apple Distribution",
    profile_name: NSE_PROFILE,
    targets: ["NotificationService"],
  )
end

# TestFlight/App Store reject a build whose CFBundleVersion (build number)
# collides with one already uploaded for the same CFBundleShortVersionString.
# The Android side derives versionCode from the git tag; iOS has no such
# derivation, so set the build number from a monotonic CI counter
# (BUILD_NUMBER env = github.run_number). No-op for a local run that doesn't
# set it — you'd bump manually or let Xcode's value stand.
def set_ci_build_number
  bn = ENV["BUILD_NUMBER"]
  return if bn.nil? || bn.empty?
  increment_build_number(xcodeproj: "Speakeasy.xcodeproj", build_number: bn)
end

# Spaceship token from the same ASC API key env the rest of the lane uses,
# so we can talk to App Store Connect directly (list beta groups).
def asc_token
  require "spaceship"
  require "base64"
  content = ENV.fetch("ASC_KEY_CONTENT")
  content = Base64.decode64(content) if ENV["ASC_KEY_CONTENT_BASE64"] == "true"
  Spaceship::ConnectAPI::Token.create(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key: content,
  )
end

# Which external TestFlight groups to auto-release each beta build to.
# The lane uploaded builds but NEVER released them to external testers
# (distribute_external was false, no groups) — so external testers only
# ever saw builds someone released BY HAND in App Store Connect, and went
# stale the moment nobody did that step. Fix it without hardcoding a group
# name (which isn't in the repo and which CI can't be told out-of-band):
# ask App Store Connect, at release time, for every EXTERNAL group on the
# app and release to all of them. `TESTFLIGHT_EXTERNAL_GROUPS` (comma-sep)
# overrides if ever needed. Failure is non-fatal — we fall back to the old
# upload-only behavior so a release can never be WORSE than before.
def external_beta_group_names
  override = (ENV["TESTFLIGHT_EXTERNAL_GROUPS"] || "").split(",").map(&:strip).reject(&:empty?)
  return override unless override.empty?
  Spaceship::ConnectAPI.token = asc_token
  app = Spaceship::ConnectAPI::App.find(APP_IDENTIFIER)
  names = app.get_beta_groups.reject(&:is_internal_group).map(&:name)
  UI.message("External TestFlight groups discovered: #{names.inspect}")
  names
rescue => e
  UI.important("Could not list external beta groups (#{e.message}); uploading without external distribution.")
  []
end

platform :ios do
  desc "Install CocoaPods (USE_FRAMEWORKS=static for the LibSignalClient Swift pod)"
  lane :pods do
    sh("cd .. && USE_FRAMEWORKS=static pod install")
  end

  desc "Create/refresh the App Store signing cert + profiles via match. Run " \
       "locally OR via the ios-certs.yml workflow_dispatch (needs a WRITE " \
       "deploy key). Regenerates a profile per app_identifier in the Matchfile."
  lane :certs do
    # Unlocked keychain for non-interactive cert install (CI / SSH).
    setup_ci(force: true)
    match(type: "appstore", readonly: false, api_key: asc_api_key)
  end

  desc "Sync signing (read-only — for CI, after `certs` has populated the repo)"
  lane :signing do
    match(type: "appstore", readonly: true, api_key: asc_api_key)
  end

  desc "Build + upload to TestFlight"
  lane :beta do
    # Create a dedicated, unlocked keychain with the signing key's partition
    # list set for NON-INTERACTIVE codesign. Without this, codesign blocks on
    # a GUI "allow access" prompt that never comes — on a CI runner it hangs
    # until the job timeout; over SSH it fails with errSecInternalComponent.
    setup_ci(force: true)
    key = asc_api_key
    match(type: "appstore", readonly: is_ci, api_key: key)
    pin_signing
    set_ci_build_number
    build_app(
      workspace: WORKSPACE,
      scheme: SCHEME,
      export_method: "app-store",
      export_options: { provisioningProfiles: { APP_IDENTIFIER => PROFILE, EXT_IDENTIFIER => EXT_PROFILE, NSE_IDENTIFIER => NSE_PROFILE } },
      output_directory: "build",
      output_name: "Speakeasy.ipa",
      clean: true,
    )
    groups = external_beta_group_names
    distribute = !groups.empty?
    upload_to_testflight(
      api_key: key,
      # Auto-release to every external group (so testers actually get the
      # build — that release step used to be manual and was the real reason
      # builds went stale). Releasing REQUIRES a processed build, so we wait
      # only when we're distributing; with no groups we keep the old fast
      # upload-and-go. Builds on an already-approved version skip Apple's
      # beta review and reach testers in minutes; the first build of a NEW
      # version waits ~24h for review (a reason to keep the version stable).
      distribute_external: distribute,
      groups: distribute ? groups : nil,
      notify_external_testers: distribute,
      skip_waiting_for_build_processing: !distribute,
      # Apple requires a "what's new" note for any externally-distributed
      # build. Generic default keeps the release unblocked; override per
      # release with TESTFLIGHT_CHANGELOG.
      changelog: distribute ? (ENV["TESTFLIGHT_CHANGELOG"] || "Bug fixes and improvements.") : nil,
    )
  end

  desc "Build + upload to the App Store (NOT auto-submitted for review)"
  lane :release do
    setup_ci(force: true) # non-interactive codesign keychain — see beta lane.
    key = asc_api_key
    match(type: "appstore", readonly: is_ci, api_key: key)
    pin_signing
    set_ci_build_number
    build_app(
      workspace: WORKSPACE,
      scheme: SCHEME,
      export_method: "app-store",
      export_options: { provisioningProfiles: { APP_IDENTIFIER => PROFILE, EXT_IDENTIFIER => EXT_PROFILE, NSE_IDENTIFIER => NSE_PROFILE } },
      output_directory: "build",
      output_name: "Speakeasy.ipa",
      clean: true,
    )
    upload_to_app_store(
      api_key: key,
      submit_for_review: false, # flip to true once the listing is review-ready
      force: true, # skip the HTML metadata preview prompt
      skip_screenshots: true,
      skip_metadata: false,
      precheck_include_in_app_purchases: false,
    )
  end

  desc "Push App Store listing metadata + screenshots only (no binary). " \
       "iOS analog of play-listing.yml. Reads fastlane/metadata/<locale>/ " \
       "+ fastlane/screenshots/<locale>/."
  lane :listing do
    upload_to_app_store(
      api_key: asc_api_key,
      skip_binary_upload: true,
      skip_metadata: false,
      # Screenshots are heavy + change rarely; toggle with SKIP_SCREENSHOTS=true
      # (e.g. before any captures exist) so a metadata-only push still works.
      skip_screenshots: ENV["SKIP_SCREENSHOTS"] == "true",
      overwrite_screenshots: true,
      primary_category: "SOCIAL_NETWORKING",
      force: true, # no interactive HTML preview
      run_precheck_before_submit: false,
      precheck_include_in_app_purchases: false,
    )
  end
end
