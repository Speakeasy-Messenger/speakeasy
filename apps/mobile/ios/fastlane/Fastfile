# Speakeasy iOS — fastlane lanes.
#
# Auth: App Store Connect API key (no Apple ID password / 2FA). The key
# parts are injected via env (sourced from the squire vault locally, and
# from GitHub Actions secrets in CI):
#   ASC_KEY_ID            — the key id (e.g. YJV2ZFM84L)
#   ASC_ISSUER_ID         — the issuer UUID
#   ASC_KEY_CONTENT       — the .p8 private key contents (PEM, with newlines)
#   ASC_KEY_CONTENT_BASE64 — "true" if ASC_KEY_CONTENT is base64-encoded
# Signing: fastlane match (git storage — Speakeasy-Messenger/speakeasy-certs),
#   unlocked with MATCH_PASSWORD.
#
# Pods must be installed first (USE_FRAMEWORKS=static — LibSignalClient is a
# Swift pod). The CI workflow + the `pods` lane handle that.

default_platform(:ios)

APP_IDENTIFIER = "xyz.speakeasyapp.app".freeze
WORKSPACE = "Speakeasy.xcworkspace".freeze
SCHEME = "Speakeasy".freeze
TEAM_ID = "89KT3SWYAF".freeze
PROFILE = "match AppStore #{APP_IDENTIFIER}".freeze
# Share Extension target — its own bundle id + match profile (App Group).
EXT_IDENTIFIER = "xyz.speakeasyapp.app.ShareExtension".freeze
EXT_PROFILE = "match AppStore #{EXT_IDENTIFIER}".freeze

def asc_api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_content: ENV.fetch("ASC_KEY_CONTENT"),
    is_key_content_base64: ENV["ASC_KEY_CONTENT_BASE64"] == "true",
    in_house: false,
  )
end

# Pin manual signing + the match profile on the app target at build time,
# so we never depend on whatever signing the checked-in pbxproj happens to
# carry. Ephemeral on CI; on a dev Mac it edits the project — `git checkout`
# the pbxproj afterward if you don't want the change.
def pin_signing
  update_code_signing_settings(
    path: "Speakeasy.xcodeproj",
    use_automatic_signing: false,
    team_id: TEAM_ID,
    bundle_identifier: APP_IDENTIFIER,
    code_sign_identity: "Apple Distribution",
    profile_name: PROFILE,
    targets: ["Speakeasy"],
  )
  # Same, for the Share Extension target (its own bundle id + profile).
  update_code_signing_settings(
    path: "Speakeasy.xcodeproj",
    use_automatic_signing: false,
    team_id: TEAM_ID,
    bundle_identifier: EXT_IDENTIFIER,
    code_sign_identity: "Apple Distribution",
    profile_name: EXT_PROFILE,
    targets: ["ShareExtension"],
  )
end

# TestFlight/App Store reject a build whose CFBundleVersion (build number)
# collides with one already uploaded for the same CFBundleShortVersionString.
# The Android side derives versionCode from the git tag; iOS has no such
# derivation, so set the build number from a monotonic CI counter
# (BUILD_NUMBER env = github.run_number). No-op for a local run that doesn't
# set it — you'd bump manually or let Xcode's value stand.
def set_ci_build_number
  bn = ENV["BUILD_NUMBER"]
  return if bn.nil? || bn.empty?
  increment_build_number(xcodeproj: "Speakeasy.xcodeproj", build_number: bn)
end

platform :ios do
  desc "Install CocoaPods (USE_FRAMEWORKS=static for the LibSignalClient Swift pod)"
  lane :pods do
    sh("cd .. && USE_FRAMEWORKS=static pod install")
  end

  desc "Create/refresh the App Store signing cert + profiles via match. Run " \
       "locally OR via the ios-certs.yml workflow_dispatch (needs a WRITE " \
       "deploy key). Regenerates a profile per app_identifier in the Matchfile."
  lane :certs do
    # Unlocked keychain for non-interactive cert install (CI / SSH).
    setup_ci(force: true)
    match(type: "appstore", readonly: false, api_key: asc_api_key)
  end

  desc "Sync signing (read-only — for CI, after `certs` has populated the repo)"
  lane :signing do
    match(type: "appstore", readonly: true, api_key: asc_api_key)
  end

  desc "Build + upload to TestFlight"
  lane :beta do
    # Create a dedicated, unlocked keychain with the signing key's partition
    # list set for NON-INTERACTIVE codesign. Without this, codesign blocks on
    # a GUI "allow access" prompt that never comes — on a CI runner it hangs
    # until the job timeout; over SSH it fails with errSecInternalComponent.
    setup_ci(force: true)
    key = asc_api_key
    match(type: "appstore", readonly: is_ci, api_key: key)
    pin_signing
    set_ci_build_number
    build_app(
      workspace: WORKSPACE,
      scheme: SCHEME,
      export_method: "app-store",
      export_options: { provisioningProfiles: { APP_IDENTIFIER => PROFILE, EXT_IDENTIFIER => EXT_PROFILE } },
      output_directory: "build",
      output_name: "Speakeasy.ipa",
      clean: true,
    )
    upload_to_testflight(
      api_key: key,
      skip_waiting_for_build_processing: true,
      distribute_external: false,
    )
  end

  desc "Build + upload to the App Store (NOT auto-submitted for review)"
  lane :release do
    setup_ci(force: true) # non-interactive codesign keychain — see beta lane.
    key = asc_api_key
    match(type: "appstore", readonly: is_ci, api_key: key)
    pin_signing
    set_ci_build_number
    build_app(
      workspace: WORKSPACE,
      scheme: SCHEME,
      export_method: "app-store",
      export_options: { provisioningProfiles: { APP_IDENTIFIER => PROFILE, EXT_IDENTIFIER => EXT_PROFILE } },
      output_directory: "build",
      output_name: "Speakeasy.ipa",
      clean: true,
    )
    upload_to_app_store(
      api_key: key,
      submit_for_review: false, # flip to true once the listing is review-ready
      force: true, # skip the HTML metadata preview prompt
      skip_screenshots: true,
      skip_metadata: false,
      precheck_include_in_app_purchases: false,
    )
  end

  desc "Push App Store listing metadata + screenshots only (no binary). " \
       "iOS analog of play-listing.yml. Reads fastlane/metadata/<locale>/ " \
       "+ fastlane/screenshots/<locale>/."
  lane :listing do
    upload_to_app_store(
      api_key: asc_api_key,
      skip_binary_upload: true,
      skip_metadata: false,
      # Screenshots are heavy + change rarely; toggle with SKIP_SCREENSHOTS=true
      # (e.g. before any captures exist) so a metadata-only push still works.
      skip_screenshots: ENV["SKIP_SCREENSHOTS"] == "true",
      overwrite_screenshots: true,
      primary_category: "SOCIAL_NETWORKING",
      force: true, # no interactive HTML preview
      run_precheck_before_submit: false,
      precheck_include_in_app_purchases: false,
    )
  end

  desc "Attach an ALREADY-UPLOADED build to the editable App Store version " \
       "and submit it for review — no binary build, talks to ASC only. For " \
       "resubmitting after a rejection when the build picker can't be reached " \
       "(e.g. App Store Connect on mobile). Build number via SUBMIT_BUILD_NUMBER."
  lane :submit_build do
    require "spaceship"
    require "base64"
    # Self-contained ASC token (don't depend on other Fastfile helpers that
    # may not exist on whatever branch the workflow runs from).
    asc_key = ENV.fetch("ASC_KEY_CONTENT")
    asc_key = Base64.decode64(asc_key) if ENV["ASC_KEY_CONTENT_BASE64"] == "true"
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key: asc_key,
    )
    app = Spaceship::ConnectAPI::App.find(APP_IDENTIFIER)
    UI.message("App id=#{app.id} (#{APP_IDENTIFIER})")

    # Print every version + its state so we can see what's actually editable
    # (deliver's submit couldn't find an 'editable version' — diagnose why).
    versions = app.get_app_store_versions(includes: "appStoreVersionSubmission")
    versions.each do |v|
      UI.message("VERSION #{v.version_string} platform=#{v.platform} state=#{v.app_store_state} id=#{v.id}")
    end

    target = ENV.fetch("APP_VERSION", "1.0")
    version = versions.find { |v| v.version_string == target }
    UI.user_error!("No iOS version '#{target}' found on the app") unless version
    UI.message("Target version #{target}: state=#{version.app_store_state} id=#{version.id}")

    build_num = ENV.fetch("SUBMIT_BUILD_NUMBER")
    builds = Spaceship::ConnectAPI::Build.all(
      app_id: app.id, version: target, build_number: build_num,
    )
    build = builds.first
    UI.user_error!("Build #{target}(#{build_num}) not found in App Store Connect") unless build
    UI.message("Found build #{target}(#{build_num}) id=#{build.id} state=#{build.processing_state}")

    # Attach the build to the version (the step that can't be done in ASC
    # mobile web). Submitting for review is then a single button on mobile.
    version.select_build(build_id: build.id)
    UI.success("Attached build #{target}(#{build_num}) to version #{version.id}. " \
               "Now tap Submit for Review in App Store Connect.")
  end
end
